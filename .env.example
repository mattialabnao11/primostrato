# Copia questo file in .env e compila con i tuoi valori
# NON committare il file .env su GitHub!

# Stringa di connessione Neon DB
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Chiave segreta JWT — generane una casuale lunga almeno 32 caratteri
# Puoi usare: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sostituisci-con-una-stringa-casuale-lunga-almeno-32-caratteri

# Porta locale (opzionale, default 3000)
PORT=3000
